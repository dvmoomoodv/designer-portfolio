        "overview_kicker": { "ko": "", "en": "Overview" },
        "overview_paragraphs": [
          { "id": "o1", "text": { "ko": "", "en": "Artificial Aesthetics is an image-led study that examines how machine-generated visual language begins to resemble memory, citation, and repetition. The project was developed as both a visual sequence and an archival interface." } },
          { "id": "o2", "text": { "ko": "", "en": "The work explores transitions between stillness and pattern. Individual frames were composed to feel self-contained, while the sequence as a whole suggests a shifting visual argument. The web presentation is intentionally restrained, allowing spacing and image order to carry much of the rhythm." } }
        ],
        "concept_kicker": { "ko": "", "en": "Concept / Process" },
        "concept_blocks": [
          { "id": "cb1", "title": { "ko": "", "en": "Research framing" }, "body": { "ko": "", "en": "The project began with a set of notes on synthetic realism, unreliable memory, and archival sequencing. These notes shaped both the image tone and the presentation logic." } },
          { "id": "cb2", "title": { "ko": "", "en": "Visual language" },  "body": { "ko": "", "en": "A limited palette, soft contrast, and repeated spatial motifs were used to maintain continuity across the series while avoiding decorative excess." } }
        ],
